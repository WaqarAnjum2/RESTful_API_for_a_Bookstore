{
  "info": {
    "_postman_id": "5a4e7b1f-2a7b-4d96-8c9d-2e5f4d9fb001",
    "name": "Books CRUD API",
    "description": "Postman collection for the books CRUD endpoints only.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000", "type": "string" },
    { "key": "bookId", "value": "", "type": "string" },
    { "key": "search", "value": "", "type": "string" },
    { "key": "page", "value": "1", "type": "string" },
    { "key": "limit", "value": "10", "type": "string" }
  ],
  "item": [
    {
      "name": "Books",
      "item": [
        {
          "name": "Create Book",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Atomic Habits\",\n  \"author\": \"James Clear\",\n  \"price\": 20,\n  \"isbn\": \"1234567890\",\n  \"publishedDate\": \"2018-10-16\"\n}"
            },
            "url": "{{baseUrl}}/books"
          }
        },
        {
          "name": "List Books",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/books?search={{search}}&page={{page}}&limit={{limit}}"
          }
        },
        {
          "name": "Get Book By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/books/{{bookId}}"
          }
        },
        {
          "name": "Update Book",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 25,\n  \"publishedDate\": \"2018-10-16\"\n}"
            },
            "url": "{{baseUrl}}/books/{{bookId}}"
          }
        },
        {
          "name": "Delete Book",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/books/{{bookId}}"
          }
        }
      ]
    }
  ]
}